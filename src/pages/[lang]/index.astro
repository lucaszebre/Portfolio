---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Hero from "@/components/Hero.astro";
import Skills from "@/components/Skills.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import BlogCard from "@/components/BlogCard.astro";
import ContactForm from "@/components/ContactForm.astro";
import Passions from "@/components/Passions.astro";
import { getCollection } from "astro:content";
import { getLangFromUrl, useTranslations, getCollectionName } from "@/i18n/utils";
import type { Lang } from "@/i18n/utils";

export async function getStaticPaths() {
  return [{ params: { lang: "en" } }, { params: { lang: "fr" } }];
}

const { lang } = Astro.params as { lang: Lang };
const t = useTranslations(lang);
const locale = lang;

const allProjects = await getCollection(getCollectionName("projects", lang) as "projects" | "projects-fr");
const blogCollectionName = getCollectionName("blog", lang) as "blog" | "blog-fr";
const allPosts = await getCollection(blogCollectionName);

const projects = allProjects.sort((a, b) => a.data.order - b.data.order);
const featuredProject = projects.find((p) => p.data.featured);
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title={t("site.title")} description={t("site.description")} lang={lang}>
  <Hero lang={lang} />

  {
    featuredProject && (
      <section class="py-16">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-white">{t("featured.title")}</h2>
          <a href={`/${lang}/projects`} class="text-sm text-accent hover:text-accent-hover transition-colors">
            {t("featured.viewAll")} &rarr;
          </a>
        </div>
        <div class="grid md:grid-cols-2 gap-6 max-w-3xl">
          <ProjectCard
            title={featuredProject.data.title}
            description={featuredProject.data.description}
            tags={featuredProject.data.tags}
            image={featuredProject.data.image}
            slug={featuredProject.slug}
            lang={lang}
          />
        </div>
      </section>
    )
  }

  {
    latestPosts.length > 0 && (
      <section class="py-16">
        <div class="flex items-center justify-between mb-8">
          <h2 class="text-2xl font-bold text-white">{t("latestPosts.title")}</h2>
          <a href={`/${lang}/blog`} class="text-sm text-accent hover:text-accent-hover transition-colors">
            {t("latestPosts.viewAll")} &rarr;
          </a>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
          {latestPosts.map((post) => (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              tags={post.data.tags}
              slug={post.slug}
              lang={lang}
            />
          ))}
        </div>
      </section>
    )
  }

  <Skills lang={lang} />
  <Passions lang={lang} />
  <ContactForm lang={lang} />
</BaseLayout>
