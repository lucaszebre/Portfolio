---
import { useTranslations } from "@/i18n/utils";
import type { Lang } from "@/i18n/utils";

interface Props {
  lang?: Lang;
}

const { lang = "en" } = Astro.props;
const t = useTranslations(lang);
---

<section class="py-16">
  <h2 class="text-2xl font-bold text-white mb-4 text-center">{t("passions.title")}</h2>
  <p class="text-muted text-center max-w-2xl mx-auto mb-12">
    {t("passions.intro")}
  </p>

  <div class="flex flex-col md:flex-row gap-8 max-w-4xl mx-auto">
    <div class="w-full md:w-1/2">
      <div class="rounded-xl overflow-hidden border border-surface-light mb-4">
        <img
          src="/assets/sorbonne.jpg"
          alt={t("passions.learning.title")}
          class="w-full h-48 object-cover"
          loading="lazy"
        />
      </div>
      <h3 class="text-lg font-semibold text-white mb-2">{t("passions.learning.title")}</h3>
      <p class="text-sm text-muted">{t("passions.learning.text")}</p>
    </div>

    <div class="w-full md:w-1/2">
      <div class="rounded-xl overflow-hidden border border-surface-light mb-4">
        <img
          src="/assets/exploring.jpg"
          alt={t("passions.skating.title")}
          class="w-full h-48 object-cover"
          loading="lazy"
        />
      </div>
      <h3 class="text-lg font-semibold text-white mb-2">{t("passions.skating.title")}</h3>
      <p class="text-sm text-muted">{t("passions.skating.text")}</p>
    </div>
  </div>
</section>
