---
import type { Lang } from "@/i18n/utils";

interface Props {
  title: string;
  description: string;
  tags: string[];
  image: string;
  slug: string;
  lang?: Lang;
}

const { title, description, tags, image, slug, lang = "en" } = Astro.props;
---

<a
  href={`/${lang}/projects/${slug}`}
  class="group block bg-surface rounded-xl overflow-hidden border border-surface-light hover:border-accent/30 transition-colors"
>
  <div class="aspect-video overflow-hidden bg-surface-light">
    <img
      src={image}
      alt={title}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
      loading="lazy"
    />
  </div>
  <div class="p-5">
    <h3 class="text-lg font-semibold text-white mb-2 group-hover:text-accent transition-colors">
      {title}
    </h3>
    <p class="text-sm text-muted mb-3 line-clamp-2">{description}</p>
    <div class="flex flex-wrap gap-1.5">
      {
        tags.slice(0, 4).map((tag) => (
          <span class="text-xs px-2 py-0.5 bg-surface-light text-muted rounded">
            {tag}
          </span>
        ))
      }
    </div>
  </div>
</a>
